{
	"name": "meadow-connection-sqlite-browser",
	"version": "1.0.2",
	"description": "Meadow SQLite connection provider for the browser (sql.js / WASM)",
	"main": "source/Meadow-Connection-SQLite-Browser.js",
	"scripts": {
		"start": "node source/Meadow-Connection-SQLite-Browser.js",
		"build": "npx quack build",
		"test": "npx quack test",
		"tests": "npx quack test -g",
		"coverage": "npx quack coverage",
		"test-browser": "npx mocha -u tdd --exit --timeout 60000 test/Browser_Integration_tests.js"
	},
	"mocha": {
		"diff": true,
		"extension": [
			"js"
		],
		"package": "./package.json",
		"reporter": "spec",
		"slow": "75",
		"timeout": "10000",
		"ui": "tdd",
		"watch-files": [
			"source/**/*.js",
			"test/**/*.js"
		],
		"watch-ignore": [
			"lib/vendor"
		]
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/stevenvelozo/meadow-connection-sqlite-browser.git"
	},
	"keywords": [
		"meadow",
		"sqlite",
		"browser",
		"sql.js",
		"wasm"
	],
	"author": "Steven Velozo <steven@velozo.com> (http://velozo.com/)",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/stevenvelozo/meadow-connection-sqlite-browser/issues"
	},
	"homepage": "https://github.com/stevenvelozo/meadow-connection-sqlite-browser",
	"devDependencies": {
		"fable": "^3.1.63",
		"puppeteer": "^24.38.0",
		"quackage": "^1.1.0",
		"retold-harness": "^1.1.2"
	},
	"browser": {
		"sql.js": false
	},
	"dependencies": {
		"fable-serviceproviderbase": "^3.0.19",
		"sql.js": "^1.14.1"
	}
}
